# --- PostgreSQL (используется и docker-compose, и backend) ---
POSTGRES_USER=mountest
POSTGRES_PASSWORD=mountest
POSTGRES_DB=mountest
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# --- Backend ---
APP_PORT=8080
# DATABASE_URL имеет приоритет, если задан. Иначе собирается из POSTGRES_*.
DATABASE_URL=postgres://mountest:mountest@localhost:5432/mountest?sslmode=disable

# Секрет для подписи JWT (поменяйте на длинную случайную строку)
JWT_SECRET=change-me-in-production-please-32+chars

# Дефолтный админ, создаётся при старте, если ещё нет
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Запускать ли сидер (демо-предметы, вариант, вопросы)
SEED_DEMO=true

# CORS — origin фронта (Vite по умолчанию 5173)
CORS_ORIGIN=http://localhost:5173

# --- Frontend ---
VITE_API_BASE=http://localhost:8080/api
