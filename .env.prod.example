# --- Домен и сертификат ---
# DNS A-запись DOMAIN должна указывать на IP сервера ДО первого `up`.
DOMAIN=mountest.example.com
# email для уведомлений Let's Encrypt
CADDY_EMAIL=admin@example.com

# --- PostgreSQL ---
POSTGRES_USER=mountest
# Сильный пароль (никаких 'mountest'!)
POSTGRES_PASSWORD=please-generate-a-strong-password
POSTGRES_DB=mountest

# --- Backend ---
# openssl rand -hex 32
JWT_SECRET=please-generate-a-32-byte-hex-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-set-a-strong-admin-password
# В проде сидер демо-данных НЕ нужен
SEED_DEMO=false
